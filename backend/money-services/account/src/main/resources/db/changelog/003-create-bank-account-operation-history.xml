<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="003-create-bank-account-operation-history" author="aleksey.z">
        <createTable tableName="bank_account_operation_history">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="action_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="write_off_amount" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>

            <column name="dept_after_operation" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>

            <column name="bank_account_from_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="bank_account_to_id" type="UUID"/>

            <column name="operation_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="update_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="bank_account_operation_history"
                baseColumnNames="bank_account_from_id"
                referencedTableName="bank_account"
                referencedColumnNames="id"
                constraintName="fk_ba_operation_from"/>

        <addForeignKeyConstraint
                baseTableName="bank_account_operation_history"
                baseColumnNames="bank_account_to_id"
                referencedTableName="bank_account"
                referencedColumnNames="id"
                constraintName="fk_ba_operation_to"/>

        <createIndex tableName="bank_account_operation_history" indexName="idx_ba_operation_from">
            <column name="bank_account_from_id"/>
        </createIndex>

        <createIndex tableName="bank_account_operation_history" indexName="idx_ba_operation_to">
            <column name="bank_account_to_id"/>
        </createIndex>

        <createIndex tableName="bank_account_operation_history" indexName="idx_ba_operation_time">
            <column name="operation_time"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>